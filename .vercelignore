# Files/folders to exclude from the Vercel deployment.
# Vercel free tier limits: 100MB per file, 1GB total deploy size.

# Note: the only video committed to the repo is the web-optimized 94MB
# Video/hero.mp4 (under Vercel's 100MB/file limit), so Video/ is NOT
# excluded — it must deploy for the hero reel to play. The 3GB source and
# 327MB full-length versions are kept local via .gitignore (never in repo).

# Mac/editor junk
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Source assets that aren't referenced by the site (saves bandwidth)
*.psd
*.ai
*.sketch

# Local dev / temp files
node_modules/
.env
.env.local
